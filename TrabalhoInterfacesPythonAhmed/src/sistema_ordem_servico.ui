  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #eeeeee; }
QLabel#lblTitulo, QLabel#lblLoginTitulo { font-size: 22px; font-weight: bold; color: #222222; }
QLabel#lblSubtitulo { color: #444444; font-size: 12px; }
QFrame#loginCard, QFrame#cardCliente, QFrame#cardCarro, QFrame#cardServico, QFrame#cardOS, QFrame#cardListarOS {
    background-color: #f8f8f8;
    border: 1px solid #cfcfcf;
}
QFrame#topBar {
    background-color: #dddddd;
    border-radius: 0px;
}
QLabel#lblSistema { color: #222222; font-size: 18px; font-weight: bold; }
QPushButton {
    background-color: #e6e6e6;
    color: #111111;
    border: 1px solid #9c9c9c;
    padding: 6px 10px;
}
QPushButton:hover { background-color: #d7d7d7; }
QPushButton#btnExcluirCliente, QPushButton#btnExcluirCarro, QPushButton#btnExcluirServico, QPushButton#btnExcluirOS {
    background-color: #e8c5c5;
}
QPushButton#btnExcluirCliente:hover, QPushButton#btnExcluirCarro:hover, QPushButton#btnExcluirServico:hover, QPushButton#btnExcluirOS:hover {
    background-color: #ddb0b0;
}
QPushButton#btnLimparCliente, QPushButton#btnLimparCarro, QPushButton#btnLimparServico, QPushButton#btnLimparOS, QPushButton#btnSair {
    background-color: #dcdcdc;
}
QPushButton#btnLimparCliente:hover, QPushButton#btnLimparCarro:hover, QPushButton#btnLimparServico:hover, QPushButton#btnLimparOS:hover, QPushButton#btnSair:hover {
    background-color: #cccccc;
}
QPushButton#btnCardCliente, QPushButton#btnCardCarro, QPushButton#btnCardServico, QPushButton#btnCardOS, QPushButton#btnCardListarOS {
    background-color: #f5f5f5;
    color: #111111;
    border: 1px solid #bcbcbc;
    text-align: left;
    padding: 12px;
    font-size: 14px;
}
QPushButton#btnCardCliente:hover, QPushButton#btnCardCarro:hover, QPushButton#btnCardServico:hover, QPushButton#btnCardOS:hover, QPushButton#btnCardListarOS:hover {
    background-color: #eeeeee;
}
QLineEdit, QComboBox, QTextEdit, QDateEdit, QDoubleSpinBox, QSpinBox {
    background-color: white;
    border: 1px solid #aaaaaa;
    padding: 4px;
}
QTableWidget {
    background-color: white;
    border: 1px solid #bbbbbb;
    gridline-color: #dddddd;
}
QHeaderView::section {
    background-color: #dddddd;
    color: #111111;
    padding: 5px;
    font-weight: bold;
    border: 1px solid #c0c0c0;
}
QTabWidget::pane { border: none; }
QTabBar::tab {
    background: #dddddd;
    color: #222222;
    padding: 6px 12px;
    border: 1px solid #bbbbbb;
}
QTabBar::tab:selected { background: white; color: #111111; }
